# ─── Kickbase ────────────────────────────────
# Account-Mail des Bot-Users (muss in den abzufragenden Ligen Mitglied sein)
KICKBASE_EMAIL=kb.pokal.bot@gmail.com
KICKBASE_PASSWORD=your-password

# ─── Discord ─────────────────────────────────
# Bot-Token aus Discord Developer Portal → Application → Bot
DISCORD_TOKEN=
# Application ID (dieselbe Seite, oben „Application ID")
CLIENT_ID=
# (Optional) Test-Guild-ID — wenn gesetzt, werden Slash-Commands NUR in diesem
# Server registriert (sofort verfügbar). Ohne: globale Registrierung (~1h Cache).
GUILD_ID=

# Pfad zur Config (Default: ./config.json)
CONFIG_PATH=./config.json
