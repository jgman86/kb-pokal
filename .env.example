# ─── Client-Side (Vite) ───────────────────────────────
# Findest du im Supabase-Projekt unter Settings > API
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key-hier

# ─── Server-Side (nur Netlify-Env, NICHT VITE_-prefixed) ──

# Discord: Webhook-URL aus Discord-Channel → Integrationen → Webhooks
DISCORD_WEBHOOK_URL=

# Kickbase-API (für Auto-Fetch der Spieltagspunkte)
KICKBASE_EMAIL=
KICKBASE_PASSWORD=

# Supabase auch server-side verfügbar machen (für Admin-Auth der
# Kickbase-Function). Gleiche Werte wie oben, nur ohne VITE_-Prefix.
SUPABASE_URL=
SUPABASE_ANON_KEY=
