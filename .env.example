# Supabase Konfiguration
# Diese Werte findest du in deinem Supabase-Projekt unter Settings > API
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key-hier

# Discord Webhook (nur auf Netlify setzen, nicht VITE_-prefixed!)
# Serverless-Function: netlify/functions/discord.js liest diese Variable
# Anlegen: Discord-Channel → Integrationen → Webhooks → Neuer Webhook → URL kopieren
DISCORD_WEBHOOK_URL=
